{
	"devDependencies": {
		"autoprefixer": "^10.4.14",
		"cssnano": "^6.0.1",
		"eslint": "^8.42.0",
		"eslint-config-standard": "^17.1.0",
		"eslint-plugin-import": "^2.25.2",
		"eslint-plugin-n": "^15.0.0 || ^16.0.0 ",
		"eslint-plugin-promise": "^6.0.0",
		"postcss": "^8.4.24",
		"postcss-cli": "^10.1.0",
		"postcss-scss": "^4.0.6",
		"postcss-sorting": "^8.0.2",
		"stylelint": "^15.7.0",
		"stylelint-config-standard-scss": "^9.0.0",
		"uglifyjs-folder": "^3.2.0"
	},
	"scripts": {
		"optimize-css": "postcss css/*.css -d css/",
		"optimize-scss": "postcss scss/*.scss -d scss/",
		"cssnano": "postcss css/*.css --use cssnano --no-map -d css/",
		"build": "sass --update scss:css",
		"watch": "sass --watch scss:css",
		"uglifyjs": "uglifyjs-folder js -x .js -eo build --config-file \"./uglify.json\"",
		"uglifylib": "uglifyjs-folder lib -x .js -eo lib --config-file \"./uglify.json\"",
		"stylelint": "stylelint \"scss/*.scss\""
	}
}
