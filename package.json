{
	"devDependencies": {
		"autoprefixer": "^10.4.14",
		"cssnano": "^6.0.1",
		"postcss": "^8.4.24",
		"postcss-cli": "^10.1.0",
		"postcss-scss": "^4.0.6",
		"postcss-sorting": "^8.0.2",
		"stylelint": "^15.7.0",
		"stylelint-config-standard-scss": "^9.0.0",
		"uglifyjs-folder": "^3.2.0"
	},
	"scripts": {
		"stylelint": "stylelint *.scss",
		"optimize": "postcss *.scss --replace",
		"cssnano": "postcss css/*.css --use cssnano --replace",
		"uglifyjs": "uglifyjs-folder js -x .js -eo js --config-file ./uglify.json",
		"uglifylib": "uglifyjs-folder lib -x .js -eo lib --config-file ./uglify.json"
	}
}
